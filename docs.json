  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "IDE repo",
        "href": "https://github.com/seemslegit42/docs"
      }
    ]
