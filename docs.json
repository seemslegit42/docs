              "weaver/databases",
              "weaver/storage",
              "weaver/triggers",
              "weaver/type-generation",
              "weaver/terraform"
            ]
          },
          {
            "group": "Orchestration",
            "pages": [
              "weaver/orchestration",
              "weaver/beep-swarm",
              "weaver/crewai",
              "weaver/api"
            ]
          },
          {
            "group": "Operations",
            "pages": [
